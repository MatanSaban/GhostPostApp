// ==========================================
// TRANSLATIONS (I18N ADMIN)
// ==========================================

enum TranslationStatus {
  DRAFT
  APPROVED
}

model I18nLanguage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  locale    String   @unique
  name      String
  isRTL     Boolean  @default(false)
  fallback  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations I18nTranslation[]

  @@map("i18n_languages")
}

// Application types for i18n translations
enum I18nApplication {
  PLATFORM  // gp-platform dashboard translations
  WEBSITE   // gp-ws marketing website translations
}

model I18nKey {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  key         String          @unique
  namespace   String
  application I18nApplication @default(PLATFORM)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  translations I18nTranslation[]

  @@index([namespace])
  @@index([application])
  @@index([application, namespace])
  @@map("i18n_keys")
}

model I18nTranslation {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  keyId       String            @db.ObjectId
  languageId  String            @db.ObjectId
  key         String            // Denormalized key string
  namespace   String            // Denormalized namespace
  application I18nApplication   @default(PLATFORM)  // Denormalized application
  locale      String            // Denormalized locale
  value       String
  status      TranslationStatus @default(APPROVED)
  version     Int               @default(1)
  isLatest    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  keyRel      I18nKey           @relation(fields: [keyId], references: [id], onDelete: Cascade)
  language    I18nLanguage      @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([languageId, namespace, status])
  @@index([locale, namespace, status])
  @@index([application, locale, isLatest])
  @@index([keyId])
  @@index([keyId, languageId, isLatest])
  @@map("i18n_translations")
}

// ==========================================
// BACKLINKS MARKETPLACE
// ==========================================

// A backlink listing published by the platform or a user
model BacklinkListing {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId

  // Publisher info – either the platform or a user's site
  publisherType   BacklinkPublisher   @default(PLATFORM) // PLATFORM or USER
  publisherAccountId String?          @db.ObjectId        // Account that owns the site (null for platform listings)
  publisherSiteId    String?          @db.ObjectId        // The connected site offering the backlink (null for platform listings)

  // Domain & SEO metrics
  domain          String                                  // e.g. "example.com"
  websiteName     String?                                 // Display name of the website
  domainAuthority Int?                                    // Moz DA (0-100)
  domainRating    Int?                                    // Ahrefs DR (0-100)
  urlRating       Int?                                    // Ahrefs UR (0-100)
  monthlyTraffic  Int?                                    // Estimated monthly organic traffic

  // Listing details
  title           String                                  // Short title for the listing
  description     String?                                 // Detailed description
  category        String?                                 // Niche / category (e.g. "Technology", "Health")
  language        String?              @default("en")     // Primary site language
  linkType        BacklinkLinkType     @default(DOFOLLOW) // Dofollow / Nofollow
  turnaroundDays  Int?                 @default(7)        // Expected turnaround in days
  sampleUrl       String?                                 // Example article URL on the publishing site
  contentRequirements String?                             // Publisher's content guidelines

  // Pricing
  price           Float?                                  // Direct purchase price (null = not available)
  currency        String               @default("USD")
  aiCreditsPrice  Int?                                    // AI credits price (null = not available)

  // Inventory
  maxSlots        Int?                                    // Max backlinks to sell (null = unlimited)
  soldCount       Int                  @default(0)

  // Publishing
  publishMode     String?              @default("manual") // "auto" (WordPress + plugin) or "manual"

  // Cached AI translations: { "he": "translated title", "en": "..." }
  titleTranslations Json?

  // Status
  status          BacklinkListingStatus @default(ACTIVE)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  purchases       BacklinkPurchase[]

  @@index([publisherAccountId])
  @@index([publisherSiteId])
  @@index([status, isActive])
  @@index([category])
  @@index([domain])
}

// A purchase / order of a backlink
model BacklinkPurchase {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId

  // Who bought it
  buyerAccountId  String                @db.ObjectId
  buyerSiteId     String                @db.ObjectId  // The site the backlink points to
  listingId       String                @db.ObjectId

  // Purchase details
  paymentMethod   BacklinkPaymentMethod               // PLAN_ALLOCATION, DIRECT, AI_CREDITS
  amountPaid      Float?                              // Money paid (for DIRECT)
  currency        String                @default("USD")
  creditsPaid     Int?                                // AI credits paid (for AI_CREDITS)

  // Link details provided by buyer
  targetUrl       String                              // URL on buyer's site to link to
  anchorText      String?                             // Preferred anchor text

  // Fulfillment
  status          BacklinkPurchaseStatus @default(PENDING)
  publishedUrl    String?                             // URL where the backlink was placed
  publishedAt     DateTime?
  rejectedReason  String?

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  // Relations
  listing         BacklinkListing       @relation(fields: [listingId], references: [id])

  @@index([buyerAccountId])
  @@index([buyerSiteId])
  @@index([listingId])
  @@index([status])
}

enum BacklinkPublisher {
  PLATFORM    // Listed by the platform itself
  USER        // Listed by a user selling from their connected site
}

enum BacklinkLinkType {
  DOFOLLOW
  NOFOLLOW
}

enum BacklinkListingStatus {
  ACTIVE
  PAUSED
  SOLD_OUT
  DRAFT
  ARCHIVED
}

enum BacklinkPaymentMethod {
  PLAN_ALLOCATION   // Uses monthly backlink quota from plan
  DIRECT            // Direct monetary payment
  AI_CREDITS        // Paid with AI credits
}

enum BacklinkPurchaseStatus {
  PENDING           // Awaiting publisher action
  APPROVED          // Publisher approved, pending placement
  PUBLISHED         // Backlink is live
  REJECTED          // Publisher rejected the order
  REFUNDED          // Purchase was refunded
  CANCELED          // Buyer canceled
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  accountId   String   @db.ObjectId
  type        String   // "audit_complete" | "audit_failed" | ...
  title       String   // translation key, e.g. "notifications.auditComplete.title"
  message     String   // translation key, e.g. "notifications.auditComplete.message"
  link        String?  // e.g. "/dashboard/technical-seo/site-audit"
  data        Json?    // extra payload: { siteId, siteName, score, deviceType, auditId }
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ==========================================
// PUSH QUESTIONS (Admin-managed questions for users)
// ==========================================

// Questions that superadmin can push to users on the site-profile page
model PushQuestion {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  order           Int                 @default(0)
  question        String              // The question text (English - base language)
  description     String?             // Optional description/hint
  questionType    PushQuestionType    @default(TEXT)
  
  // For CHOICE/MULTI_CHOICE types - options as JSON array of strings
  options         Json?               // ["option1", "option2", ...]
  
  // Targeting - who sees this question
  targetAll       Boolean             @default(true)  // Show to all sites
  targetSiteIds   String[]            @db.ObjectId    // Specific site IDs if not targetAll
  
  // Whether this question is required or can be skipped
  required        Boolean             @default(false)
  
  // Category for grouping in admin UI
  category        String?
  
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  answers         PushQuestionAnswer[]
  translations    PushQuestionTranslation[]

  @@index([isActive, order])
  @@map("push_questions")
}

// Translations for push questions
model PushQuestionTranslation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId  String   @db.ObjectId
  language    Language
  question    String   // Translated question text
  description String?  // Translated description
  options     Json?    // Translated options for CHOICE/MULTI_CHOICE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pushQuestion PushQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, language])
  @@map("push_question_translations")
}

// User answers to push questions
model PushQuestionAnswer {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId      String   @db.ObjectId
  siteId          String   @db.ObjectId
  userId          String   @db.ObjectId
  
  // The answer value - text for TEXT type, JSON array for MULTI_CHOICE
  answer          String?
  
  // Whether user skipped this question
  skipped         Boolean  @default(false)
  
  answeredAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  question        PushQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, siteId])
  @@index([siteId])
  @@index([userId])
  @@map("push_question_answers")
}

enum PushQuestionType {
  TEXT          // Free text input
  TEXTAREA      // Multi-line text
  CHOICE        // Single choice (radio)
  MULTI_CHOICE  // Multiple choice (checkboxes)
  NUMBER        // Numeric input
  URL           // URL input
}

// ==========================================
// AI AGENT
// ==========================================

// An AI agent insight, suggestion, or action.
// This is the core model for the Ghost AI Agent.
model AgentInsight {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  siteId        String              @db.ObjectId
  accountId     String              @db.ObjectId

  // Classification
  category      AgentInsightCategory   // CONTENT, TRAFFIC, KEYWORDS, COMPETITORS, TECHNICAL
  type          AgentInsightType       // DISCOVERY, SUGGESTION, ACTION, ANALYSIS, ALERT
  priority      AgentInsightPriority   @default(MEDIUM)

  // Content
  titleKey      String           // Translation key for short title
  descriptionKey String          // Translation key for description
  data          Json?            // Dynamic payload: { keywordId, entityId, position, ctr, etc. }

  // For ACTION type insights that need user approval
  status        AgentInsightStatus   @default(PENDING)
  actionType    String?              // "update_meta", "add_internal_link", "push_to_wp", etc.
  actionPayload Json?               // Data needed to execute the action
  approvedAt    DateTime?
  approvedBy    String?              @db.ObjectId
  rejectedAt    DateTime?
  executedAt    DateTime?
  executionResult Json?             // Result from executing the action

  // Source tracking
  source        String               @default("cron")  // "cron" | "manual" | "realtime"
  batchId       String?              // Groups insights generated in the same run

  // Lifecycle
  dismissedAt   DateTime?
  resolvedAt    DateTime?            // When the issue was auto-resolved (not found in latest analysis)
  expiresAt     DateTime?            // Auto-dismiss stale insights
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([siteId, status, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
  @@index([siteId, category, createdAt(sort: Desc)])
  @@map("agent_insights")
}

// Overall agent run log - one per cron/manual run per site.
model AgentRun {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  siteId        String          @db.ObjectId
  accountId     String          @db.ObjectId
  source        String          @default("cron")  // "cron" | "manual"
  status        AgentRunStatus  @default(RUNNING)
  startedAt     DateTime        @default(now())
  completedAt   DateTime?
  error         String?
  insightsCount Int             @default(0)
  summary       Json?           // { discoveries: 2, suggestions: 1, alerts: 0, ... }

  @@index([siteId, startedAt(sort: Desc)])
  @@map("agent_runs")
}

enum AgentInsightCategory {
  CONTENT       // Content optimization, thin content, outdated posts
  TRAFFIC       // Traffic spikes/drops, session patterns
  KEYWORDS      // Ranking opportunities, cannibalization
  COMPETITORS   // Competitor changes, content gaps
  TECHNICAL     // Missing meta, broken links, audit issues
}

enum AgentInsightType {
  DISCOVERY     // Agent found something noteworthy
  SUGGESTION    // Agent recommends an action
  ACTION        // Agent can perform an action (needs approval)
  ANALYSIS      // Periodic report/summary
  ALERT         // Something urgent needs attention
}

enum AgentInsightPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AgentInsightStatus {
  PENDING       // Waiting for user review (default)
  APPROVED      // User approved the action
  REJECTED      // User dismissed/rejected
  EXECUTED      // Action was executed successfully
  FAILED        // Action execution failed
  EXPIRED       // Auto-expired after expiresAt
  RESOLVED      // Issue no longer detected in latest analysis (auto-resolved)
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

// ==========================================
// WHITE-LABEL REPORTS
// ==========================================

model ReportArchive {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  siteId      String       @db.ObjectId
  accountId   String       @db.ObjectId
  generatedAt DateTime     @default(now())
  pdfUrl      String       // Cloudinary secure URL
  recipients  String[]     // Email addresses the report was sent to
  status      ReportStatus @default(DRAFT)
  month       String       // e.g., "October 2026"
  metadata    Json?        // Additional data: { score, delta, actionsCount, etc. }
  sentAt      DateTime?    // When the report was actually sent
  error       String?      // Error message if status is ERROR
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([siteId, generatedAt(sort: Desc)])
  @@index([accountId, generatedAt(sort: Desc)])
  @@map("report_archives")
}

enum ReportStatus {
  DRAFT     // Generated but not sent (for review)
  SENT      // Successfully sent to recipients
  ERROR     // Failed to send
}

// ==========================================
// WEBSITE CMS (gp-ws content management)
// ==========================================

// Site-wide SEO configuration
model WebsiteSeo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  websiteId       String   @default("gp-ws")
  
  // Site-wide defaults
  siteName        Json     // { en: "Ghost Post", he: "גוסט פוסט", fr: "Ghost Post" }
  siteUrl         String   @default("https://ghostpost.co.il")
  defaultOgImage  String?
  twitterHandle   String?
  
  // Robots defaults
  defaultRobots   String   @default("index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1")
  
  updatedAt       DateTime @updatedAt
  updatedBy       String?  @db.ObjectId
  
  @@unique([websiteId])
  @@map("website_seo")
}

// Content and SEO per locale
model WebsiteLocale {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  websiteId String   @default("gp-ws")
  locale    String   // "en", "he", "fr"
  
  // Full content dictionary (matches gp-ws i18n structure)
  content   Json
  
  // Page-level SEO per locale
  // { home: { title, description, canonical, ogImage, ogTitle, ogDescription, robots, jsonLd }, ... }
  seo       Json?
  
  // Draft system for preview before publish
  contentDraft Json?
  seoDraft     Json?
  
  // Versioning and audit
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId
  
  @@unique([websiteId, locale])
  @@map("website_locales")
}

// Blog posts managed from CMS (future expansion)
model WebsiteBlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  websiteId   String   @default("gp-ws")
  slug        String
  
  // Content per locale
  content     Json     // { en: { title, excerpt, content, ... }, he: {...}, fr: {...} }
  
  // SEO per locale
  seo         Json?    // { en: { title, description, ogImage, ... }, he: {...}, fr: {...} }
  
  // Metadata
  author      String?
  category    String?
  tags        String[]
  featuredImage String?
  
  // Publishing
  status      WebsiteContentStatus @default(DRAFT)
  publishedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.ObjectId
  
  @@unique([websiteId, slug])
  @@index([websiteId, status])
  @@map("website_blog_posts")
}

enum WebsiteContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ==========================================
// AI Cache
// ==========================================

// Generic cache for AI-generated text that should persist across sessions
// Used for e.g. recommendation explanations per locale
model AiCache {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   // Hash or composite key identifying the content
  locale    String   // Language code (e.g., "en", "he")
  content   Json     // Cached AI output (flexible structure)
  createdAt DateTime @default(now())

  @@unique([key, locale])
  @@map("ai_cache")
}
